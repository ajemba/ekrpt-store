<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Finance — EKRPT</title>
<link rel="stylesheet" href="../css/style.css"/>
<link rel="stylesheet" href="../css/portal-core.css"/>
<link rel="stylesheet" href="../css/theme-spectre-portal.css"/>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>:root{--accent:#ca8a04}.pside-logo-mark{background:#ca8a04}.role-tag{color:#fde68a}.pside-av{background:#ca8a04}</style>
</head>
<body class="portal">
<aside class="pside">
  <div class="pside-logo"><div class="pside-logo-mark"><svg viewBox="0 0 20 20"><path d="M2 4h16v2H2zM2 9h10v2H2zM2 14h13v2H2z"/></svg></div><div class="pside-brand">EKRPT Labs<span class="role-tag">Finance</span></div></div>
  <nav class="pside-nav">
    <div class="pside-section">Finance</div>
    <button class="pside-link active" onclick="nav('dashboard',this)"><span class="ic">📊</span>Overview</button>
    <button class="pside-link" onclick="nav('transactions',this)"><span class="ic">💳</span>Transactions</button>
    <button class="pside-link" onclick="nav('refunds',this)"><span class="ic">↩️</span>Refunds</button>
    <button class="pside-link" onclick="nav('orders',this)"><span class="ic">📦</span>Orders</button>
    <a class="pside-link" href="../index.html" target="_blank"><span class="ic">🌐</span>View Store</a>
  </nav>
  <div class="pside-foot"><div class="pside-user"><div class="pside-av" id="av">F</div><div><div class="pside-uname" id="uname">Finance</div><div class="pside-urole">Finance Team</div></div><button class="pside-out" onclick="Auth.signOut()">⏻</button></div></div>
</aside>
<div class="pmain">
  <div class="ptop"><div class="ptop-title" id="ptitle">Overview</div><span class="ptop-meta" id="pmeta"></span><button class="pbtn pbtn-primary" onclick="refreshAll()">↻ Refresh</button></div>
  <div class="pcontent">

    <div id="v-dashboard" class="pview active">
      <div class="palert palert-info">ℹ️ Finance can view revenue, process refunds, and review transactions. Payment processor keys are managed only by the Super Admin.</div>
      <div class="pmetrics">
        <div class="pmetric" style="--accent:#16a34a"><div class="pmetric-label">Total Payments</div><div class="pmetric-val" id="f-in">₦0</div><div class="pmetric-sub">All gateways</div><div class="pmetric-ic">⬆️</div></div>
        <div class="pmetric" style="--accent:#dc2626"><div class="pmetric-label">Refunds</div><div class="pmetric-val" id="f-refunds">₦0</div><div class="pmetric-ic">⬇️</div></div>
        <div class="pmetric"><div class="pmetric-label">Gateway Fees</div><div class="pmetric-val" id="f-fees">₦0</div><div class="pmetric-ic">🏦</div></div>
        <div class="pmetric" style="--accent:#16a34a"><div class="pmetric-label">Net Revenue</div><div class="pmetric-val" id="f-net">₦0</div><div class="pmetric-ic">💵</div></div>
      </div>
      <div style="display:grid;grid-template-columns:2fr 1fr;gap:20px">
        <div class="ppanel"><div class="ppanel-head"><span class="ppanel-title">Revenue by Gateway</span></div><div class="ppanel-body"><div class="pchart"><canvas id="gw-chart"></canvas></div></div></div>
        <div class="ppanel"><div class="ppanel-head"><span class="ppanel-title">Breakdown</span></div><div class="ppanel-body" id="gw-breakdown"></div></div>
      </div>
    </div>

    <div id="v-transactions" class="pview">
      <div class="ptoolbar"><select class="pselect" id="tx-type" onchange="renderTx()"><option value="">All types</option><option value="payment">Payments</option><option value="refund">Refunds</option><option value="fee">Fees</option></select><button class="pbtn pbtn-ghost" onclick="loadTx()">↻ Refresh</button></div>
      <div class="ppanel"><div class="ppanel-body flush"><table class="ptable"><thead><tr><th>Date</th><th>Type</th><th>Gateway</th><th>Reference</th><th>Amount</th><th>Status</th></tr></thead><tbody id="tx-body"></tbody></table></div></div>
    </div>

    <div id="v-refunds" class="pview">
      <div class="palert palert-warn">⚠️ Refunds are recorded here and mark the order as refunded. Actual money movement happens in your payment processor dashboard.</div>
      <div class="ptoolbar"><input class="psearch" id="refund-search" placeholder="Search paid orders to refund…" oninput="renderRefundable()"/><button class="pbtn pbtn-ghost" onclick="loadOrders()">↻ Refresh</button></div>
      <div class="ppanel"><div class="ppanel-body flush"><table class="ptable"><thead><tr><th>Order #</th><th>Customer</th><th>Total</th><th>Method</th><th>Action</th></tr></thead><tbody id="refundable-body"></tbody></table></div></div>
    </div>

    <div id="v-orders" class="pview">
      <div class="ptoolbar"><input class="psearch" id="o-search" placeholder="Search orders…" oninput="renderOrders()"/><button class="pbtn pbtn-ghost" onclick="loadOrders()">↻ Refresh</button></div>
      <div class="ppanel"><div class="ppanel-body flush"><table class="ptable"><thead><tr><th>Order #</th><th>Date</th><th>Total</th><th>Payment</th><th>Status</th></tr></thead><tbody id="orders-body"></tbody></table></div></div>
    </div>

  </div>
</div>

<script src="../js/config.js"></script>
<script src="../js/main.js"></script>
<script src="../js/auth.js"></script>
<script src="../js/store.js"></script>
<script src="../js/roles.js"></script>
<script src="../js/admin-ops.js"></script>
<script>
let _tx=[],_orders=[];
document.addEventListener('DOMContentLoaded',async()=>{
  if(!await RBAC.guard(['finance','super_admin']))return;
  const u=RBAC.getUser();if(u){document.getElementById('uname').textContent=u.profile?.full_name||'Finance';document.getElementById('av').textContent=(u.profile?.full_name||'F')[0].toUpperCase();}
  await refreshAll();
});
async function refreshAll(){document.getElementById('pmeta').textContent='Updated '+new Date().toLocaleTimeString('en-NG');await Promise.all([loadSummary(),loadTx(),loadOrders()]);}
function nav(v,btn){document.querySelectorAll('.pview').forEach(x=>x.classList.remove('active'));document.querySelectorAll('.pside-link').forEach(x=>x.classList.remove('active'));document.getElementById('v-'+v).classList.add('active');if(btn)btn.classList.add('active');document.getElementById('ptitle').textContent={dashboard:'Overview',transactions:'Transactions',refunds:'Refunds',orders:'Orders'}[v];}

async function loadSummary(){try{const s=await Finance.getSummary();document.getElementById('f-in').textContent=fmtNGN(s.payments);document.getElementById('f-refunds').textContent=fmtNGN(s.refunds);document.getElementById('f-fees').textContent=fmtNGN(s.fees);document.getElementById('f-net').textContent=fmtNGN(s.net);renderGwChart(s.byGateway);document.getElementById('gw-breakdown').innerHTML=Object.entries(s.byGateway).map(([g,a])=>`<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--gray-50);font-size:13px"><span style="text-transform:capitalize">${g}</span><span style="font-family:var(--font-mono)">${fmtNGN(a)}</span></div>`).join('')||'<p style="font-size:13px;color:var(--gray-300)">No payments yet</p>';}catch(e){}}
function renderGwChart(byGw){const ctx=document.getElementById('gw-chart');if(!ctx)return;if(window._gwc)window._gwc.destroy();const labels=Object.keys(byGw);const data=Object.values(byGw);window._gwc=new Chart(ctx,{type:'doughnut',data:{labels:labels.length?labels:['No data'],datasets:[{data:data.length?data:[1],backgroundColor:['#1a8fc4','#f5a623','#0070ba','#534ab7','#16a34a']}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom'}}}});}

async function loadTx(){try{_tx=await Finance.getTransactions();renderTx();}catch(e){}}
function renderTx(){const t=document.getElementById('tx-type').value;const list=_tx.filter(x=>!t||x.type===t);document.getElementById('tx-body').innerHTML=list.map(x=>`<tr><td style="font-size:12px">${new Date(x.created_at).toLocaleDateString('en-NG')}</td><td><span class="pill pill-${x.type==='refund'?'cancelled':'active'}">${x.type}</span></td><td style="text-transform:capitalize">${x.gateway||'—'}</td><td style="font-family:var(--font-mono);font-size:11px">${x.reference||'—'}</td><td style="font-family:var(--font-mono)">${fmtNGN(x.amount)}</td><td><span class="pill pill-active">${x.status}</span></td></tr>`).join('')||'<tr><td colspan="6" class="pempty">No transactions yet</td></tr>';}

async function loadOrders(){try{_orders=await Orders.getAll();renderOrders();renderRefundable();}catch(e){}}
function renderOrders(){const s=(document.getElementById('o-search').value||'').toLowerCase();const list=_orders.filter(o=>!s||o.order_number.toLowerCase().includes(s));document.getElementById('orders-body').innerHTML=list.map(o=>`<tr><td style="font-family:var(--font-mono);font-size:11px"><strong>${o.order_number}</strong></td><td style="font-size:12px">${new Date(o.created_at).toLocaleDateString('en-NG')}</td><td style="font-family:var(--font-mono)">${fmtNGN(o.total)}</td><td><span class="pill pill-${o.payment_status}">${o.payment_status}</span></td><td><span class="pill pill-${o.status}">${o.status}</span></td></tr>`).join('')||'<tr><td colspan="5" class="pempty">No orders</td></tr>';}
function renderRefundable(){const s=(document.getElementById('refund-search').value||'').toLowerCase();const list=_orders.filter(o=>o.payment_status==='paid'&&(!s||o.order_number.toLowerCase().includes(s)));document.getElementById('refundable-body').innerHTML=list.map(o=>`<tr><td style="font-family:var(--font-mono);font-size:11px"><strong>${o.order_number}</strong></td><td style="font-size:12px">${o.shipping_address?.name||o.guest_email||'Guest'}</td><td style="font-family:var(--font-mono)">${fmtNGN(o.total)}</td><td style="text-transform:capitalize">${o.payment_method||'—'}</td><td><button class="pbtn pbtn-danger" onclick="doRefund('${o.id}','${o.order_number}',${o.total})">Refund</button></td></tr>`).join('')||'<tr><td colspan="5" class="pempty">No paid orders to refund</td></tr>';}
async function doRefund(id,num,total){const reason=prompt('Refund reason for '+num+'?');if(reason===null)return;try{await Finance.refund(id,total,reason);showToast('Refund recorded for '+num+' ✓');await loadOrders();await loadSummary();await loadTx();}catch(e){showToast('Error: '+e.message,'error');}}
</script>
</body>
</html>
